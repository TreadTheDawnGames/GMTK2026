[gd_resource type="Resource" script_class="DialogueConversation" load_steps=7 format=3]

[ext_resource type="Script" path="res://resources/dialogue/dialogue_conversation.gd" id="1_conversation"]
[ext_resource type="Script" path="res://resources/dialogue/dialogue_participant.gd" id="2_participant"]
[ext_resource type="Script" path="res://resources/dialogue/dialogue_line.gd" id="3_line"]

[sub_resource type="Resource" id="Participant_miner"]
script = ExtResource("2_participant")
slot = &"miner"
display_name = "Miner"

[sub_resource type="Resource" id="Participant_traveler"]
script = ExtResource("2_participant")
slot = &"traveler"
display_name = "Traveler"

[sub_resource type="Resource" id="Line_return"]
script = ExtResource("3_line")
speaker_slot = &"traveler"
text = "You made good time. The dark below will not be as generous."

[sub_resource type="Resource" id="Line_gift"]
script = ExtResource("3_line")
speaker_slot = &"traveler"
text = "Take this Lantern Pickaxe. Its fading marks will teach you to trust the rhythm."

[sub_resource type="Resource" id="Line_miner"]
script = ExtResource("3_line")
speaker_slot = &"miner"
text = "Then I will keep the light moving."

[resource]
script = ExtResource("1_conversation")
conversation_id = &"lantern_pickaxe_gift"
participants = Array[ExtResource("2_participant")]([SubResource("Participant_miner"), SubResource("Participant_traveler")])
lines = Array[ExtResource("3_line")]([SubResource("Line_return"), SubResource("Line_gift"), SubResource("Line_miner")])
