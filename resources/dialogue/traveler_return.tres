[gd_resource type="Resource" script_class="DialogueConversation" format=3 uid="uid://bobmumfyonwg5"]

[ext_resource type="Script" uid="uid://c55utdbjdwaui" path="res://resources/dialogue/dialogue_conversation.gd" id="1_conversation"]
[ext_resource type="Script" uid="uid://ivfntthetp0i" path="res://resources/dialogue/dialogue_participant.gd" id="2_participant"]
[ext_resource type="Script" uid="uid://bwwpoalvqb7ni" path="res://resources/dialogue/dialogue_line.gd" id="3_line"]

[sub_resource type="Resource" id="Line_greeting"]
script = ExtResource("3_line")
speaker_slot = &"traveler"
text = "There you are. We're turning back."

[sub_resource type="Resource" id="Line_tinkerer"]
script = ExtResource("3_line")
speaker_slot = &"tinkerer"
text = "No tool I made is worth what waits below."

[sub_resource type="Resource" id="Line_surveyor"]
script = ExtResource("3_line")
speaker_slot = &"surveyor"
text = "I measured the rest. It is farther than it feels."

[sub_resource type="Resource" id="Line_prospector"]
script = ExtResource("3_line")
speaker_slot = &"prospector"
text = "Going farther is a fool's errand."

[sub_resource type="Resource" id="Line_question"]
script = ExtResource("3_line")
speaker_slot = &"miner"
text = "And if I still go?"

[sub_resource type="Resource" id="Line_departure"]
script = ExtResource("3_line")
speaker_slot = &"traveler"
text = "Then you go alone. We aren't going any farther."

[sub_resource type="Resource" id="Participant_miner"]
script = ExtResource("2_participant")
slot = &"miner"
display_name = "Miner"

[sub_resource type="Resource" id="Participant_traveler"]
script = ExtResource("2_participant")
slot = &"traveler"
display_name = "Traveler"

[sub_resource type="Resource" id="Participant_tinkerer"]
script = ExtResource("2_participant")
slot = &"tinkerer"
display_name = "Underground Tinkerer"

[sub_resource type="Resource" id="Participant_surveyor"]
script = ExtResource("2_participant")
slot = &"surveyor"
display_name = "Tunnel Surveyor"

[sub_resource type="Resource" id="Participant_prospector"]
script = ExtResource("2_participant")
slot = &"prospector"
display_name = "Old Prospector"

[resource]
script = ExtResource("1_conversation")
conversation_id = &"traveler_return"
participants = Array[ExtResource("2_participant")]([SubResource("Participant_miner"), SubResource("Participant_traveler"), SubResource("Participant_tinkerer"), SubResource("Participant_surveyor"), SubResource("Participant_prospector")])
lines = Array[ExtResource("3_line")]([SubResource("Line_greeting"), SubResource("Line_tinkerer"), SubResource("Line_surveyor"), SubResource("Line_prospector"), SubResource("Line_question"), SubResource("Line_departure")])
