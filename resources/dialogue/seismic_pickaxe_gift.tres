[gd_resource type="Resource" script_class="DialogueConversation" load_steps=7 format=3]

[ext_resource type="Script" path="res://resources/dialogue/dialogue_conversation.gd" id="1_conversation"]
[ext_resource type="Script" path="res://resources/dialogue/dialogue_participant.gd" id="2_participant"]
[ext_resource type="Script" path="res://resources/dialogue/dialogue_line.gd" id="3_line"]

[sub_resource type="Resource" id="Participant_miner"]
script = ExtResource("2_participant")
slot = &"miner"
display_name = "Miner"

[sub_resource type="Resource" id="Participant_surveyor"]
script = ExtResource("2_participant")
slot = &"surveyor"
display_name = "Tunnel Surveyor"

[sub_resource type="Resource" id="Line_report"]
script = ExtResource("3_line")
speaker_slot = &"surveyor"
text = "The stone is carrying every impact farther than my instruments predicted."

[sub_resource type="Resource" id="Line_gift"]
script = ExtResource("3_line")
speaker_slot = &"surveyor"
text = "Use the Seismic Pickaxe. It stores a second shock beneath each strike."

[sub_resource type="Resource" id="Line_miner"]
script = ExtResource("3_line")
speaker_slot = &"miner"
text = "One swing, two answers."

[resource]
script = ExtResource("1_conversation")
conversation_id = &"seismic_pickaxe_gift"
participants = Array[ExtResource("2_participant")]([SubResource("Participant_miner"), SubResource("Participant_surveyor")])
lines = Array[ExtResource("3_line")]([SubResource("Line_report"), SubResource("Line_gift"), SubResource("Line_miner")])
