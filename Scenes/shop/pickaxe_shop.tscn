[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://Scripts/shop/pickaxe_shop.gd" id="1_shop"]
[ext_resource type="Resource" path="res://resources/pickaxes/basic_pickaxe.tres" id="2_basic"]
[ext_resource type="Resource" path="res://resources/pickaxes/wide_pickaxe.tres" id="3_wide"]
[ext_resource type="Resource" path="res://resources/pickaxes/heavy_pickaxe.tres" id="4_heavy"]
[ext_resource type="Resource" path="res://resources/pickaxes/swift_pickaxe.tres" id="5_swift"]

[node name="PickaxeShop" type="Control" node_paths=PackedStringArray("balance_label", "item_list", "name_label", "description_label", "stats_label", "status_label", "primary_button")]
editor_description = "Reusable pickaxe shop. Supply a ShopBalance and PickaxeLoadout with configure() before opening."
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
script = ExtResource("1_shop")
stock = Array[ExtResource("2_basic")]([ExtResource("2_basic"), ExtResource("3_wide"), ExtResource("4_heavy"), ExtResource("5_swift")])
balance_label = NodePath("Dimmer/ShopPanel/Margin/Rows/Header/Balance")
item_list = NodePath("Dimmer/ShopPanel/Margin/Rows/Content/Items")
name_label = NodePath("Dimmer/ShopPanel/Margin/Rows/Content/Details/Name")
description_label = NodePath("Dimmer/ShopPanel/Margin/Rows/Content/Details/Description")
stats_label = NodePath("Dimmer/ShopPanel/Margin/Rows/Content/Details/Stats")
status_label = NodePath("Dimmer/ShopPanel/Margin/Rows/Status")
primary_button = NodePath("Dimmer/ShopPanel/Margin/Rows/Actions/Primary")

[node name="Dimmer" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.65)

[node name="ShopPanel" type="PanelContainer" parent="Dimmer"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -310.0
offset_top = -210.0
offset_right = 310.0
offset_bottom = 210.0
grow_horizontal = 2
grow_vertical = 2

[node name="Margin" type="MarginContainer" parent="Dimmer/ShopPanel"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Rows" type="VBoxContainer" parent="Dimmer/ShopPanel/Margin"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Header" type="HBoxContainer" parent="Dimmer/ShopPanel/Margin/Rows"]
layout_mode = 2

[node name="Title" type="Label" parent="Dimmer/ShopPanel/Margin/Rows/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 24
text = "Pickaxe Shop"

[node name="Balance" type="Label" parent="Dimmer/ShopPanel/Margin/Rows/Header"]
layout_mode = 2
text = "Ore: 0"
horizontal_alignment = 2

[node name="Content" type="HBoxContainer" parent="Dimmer/ShopPanel/Margin/Rows"]
custom_minimum_size = Vector2(0, 260)
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 18

[node name="Items" type="ItemList" parent="Dimmer/ShopPanel/Margin/Rows/Content"]
custom_minimum_size = Vector2(240, 0)
layout_mode = 2
size_flags_vertical = 3
allow_reselect = true

[node name="Details" type="VBoxContainer" parent="Dimmer/ShopPanel/Margin/Rows/Content"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="Name" type="Label" parent="Dimmer/ShopPanel/Margin/Rows/Content/Details"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "No pickaxe selected"

[node name="Description" type="Label" parent="Dimmer/ShopPanel/Margin/Rows/Content/Details"]
layout_mode = 2
size_flags_vertical = 3
text = ""
autowrap_mode = 2

[node name="Stats" type="Label" parent="Dimmer/ShopPanel/Margin/Rows/Content/Details"]
layout_mode = 2
text = ""

[node name="Status" type="Label" parent="Dimmer/ShopPanel/Margin/Rows"]
custom_minimum_size = Vector2(0, 24)
layout_mode = 2
text = ""

[node name="Actions" type="HBoxContainer" parent="Dimmer/ShopPanel/Margin/Rows"]
layout_mode = 2
alignment = 2
theme_override_constants/separation = 10

[node name="Close" type="Button" parent="Dimmer/ShopPanel/Margin/Rows/Actions"]
layout_mode = 2
text = "Close"

[node name="Primary" type="Button" parent="Dimmer/ShopPanel/Margin/Rows/Actions"]
custom_minimum_size = Vector2(140, 0)
layout_mode = 2
text = "Unavailable"

[connection signal="item_selected" from="Dimmer/ShopPanel/Margin/Rows/Content/Items" to="." method="_on_item_selected"]
[connection signal="pressed" from="Dimmer/ShopPanel/Margin/Rows/Actions/Close" to="." method="_on_close_button_pressed"]
[connection signal="pressed" from="Dimmer/ShopPanel/Margin/Rows/Actions/Primary" to="." method="_on_primary_button_pressed"]
